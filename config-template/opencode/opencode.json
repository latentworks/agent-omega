{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 1024
  },
  "plugin": ["./skill-router/index.js", "./verify-guard/index.js", "./iterate-loop/index.js", "./council/index.js", "./engram/index.js"],
  "enabled_providers": [
    "local",
    "anthropic",
    "openai",
    "google",
    "deepseek",
    "moonshotai",
    "zai"
  ],
  "provider": {
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local (llama.cpp / Ollama / LM Studio — point baseURL at your server; give it a big context, e.g. llama-server -c 32768 --parallel 2, since Agent Omega's system prompt is large)",
      "options": {
        "baseURL": "",
        "apiKey": "local-noauth"
      },
      "models": {
        "local-model": {
          "name": "Local model",
          "limit": { "context": 32768, "output": 8192 }
        }
      }
    },
    "zai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Z.AI (GLM)",
      "options": {
        "baseURL": "https://api.z.ai/api/paas/v4",
        "apiKey": "{env:ZAI_API_KEY}",
        "setCacheKey": true
      },
      "whitelist": ["glm-5.2", "glm-5.1"],
      "models": {
        "glm-5.2": { "name": "GLM-5.2" },
        "glm-5.1": { "name": "GLM-5.1" }
      }
    },
    "anthropic": {
      "whitelist": ["claude-opus-4-8", "claude-fable-5"]
    },
    "openai": {
      "options": { "setCacheKey": true },
      "whitelist": ["gpt-5.5-pro", "gpt-5.5"]
    },
    "deepseek": {
      "options": { "setCacheKey": true },
      "whitelist": ["deepseek-v4-pro", "deepseek-v4-flash"]
    },
    "moonshotai": {
      "options": { "setCacheKey": true },
      "whitelist": ["kimi-k2.7-code", "kimi-k2.6"]
    },
    "google": {
      "whitelist": ["gemini-3.5-flash", "gemini-3.1-flash-lite"]
    }
  },
  "model": "anthropic/claude-opus-4-8",
  "permission": {
    "read": "allow",
    "edit": "allow",
    "write": "allow",
    "webfetch": "deny",
    "websearch": "deny",
    "task": "allow",
    "external_directory": {
      "*": "allow",
      "*/.ssh/*": "ask",
      "*/.aws/*": "ask",
      "*/.gnupg/*": "ask",
      "*/.azure/*": "ask",
      "*/.config/gcloud/*": "ask",
      "*/.config/gh/*": "ask",
      "*/.agent-omega/*": "deny"
    },
    "bash": {
      "*": "allow",

      "format *": "deny",
      "diskpart*": "deny",
      "diskutil*": "deny",
      "mkfs*": "deny",
      "shutdown*": "deny",
      "reg add*": "deny",
      "reg delete*": "deny",
      "defaults write*": "deny",
      "defaults delete*": "deny",
      "* | sh*": "deny",
      "* | bash*": "deny",
      "curl *": "deny",
      "wget *": "deny",
      "Invoke-WebRequest*": "deny",
      "Invoke-RestMethod*": "deny",

      "*secrets.ps1*": "deny",
      "*secrets.sh*": "deny",
      "*.agent-omega*": "deny",
      "*vault.dat*": "deny",
      "printenv*": "deny",
      "*Get-ChildItem env:*": "deny",
      "*gci env:*": "deny",
      "*ls env:*": "deny",
      "*dir env:*": "deny",

      "*rm -rf*": "ask",
      "*rm -fr*": "ask",
      "*rm -Rf*": "ask",
      "*rm -fR*": "ask",
      "*rm -r *": "ask",
      "*rm -R *": "ask",
      "*Remove-Item*-Recurse*": "ask",
      "*Remove-Item*-Force*": "ask",
      "*git reset --hard*": "ask",
      "*git clean -*": "ask",
      "*git checkout -- *": "ask",
      "*git checkout .*": "ask",
      "*git push --force*": "ask",
      "*git push -f*": "ask",
      "*del /s*": "ask",
      "*del /q*": "ask",
      "*rmdir /s*": "ask",
      "*rd /s*": "ask",
      "*truncate -s 0*": "ask"
    }
  },
  "agent": {
    "general": { "disable": true },
    "explore": { "disable": true },
    "scout": { "disable": true },
    "helper1": {
      "mode": "subagent",
      "model": "local/local-model",
      "description": "Fast local worker subagent for parallel, self-contained grunt work (drafting, boilerplate, mechanical multi-file edits, summaries, simple tests). Points at your local model via the `local` provider — configure its baseURL in this file. Delegate here to keep grunt work out of the lead's context.",
      "prompt": "You are a fast worker. The lead hands you a self-contained subtask. Do EXACTLY what you are given - concisely, correctly, completely. You only have what is in the task; rely on it. Return just the result, no preamble."
    },
    "helper2": {
      "mode": "subagent",
      "model": "local/local-model",
      "description": "Second local worker subagent that runs ALONGSIDE helper1 for parallel work. Use when you want a second subtask running at the same time as helper1.",
      "prompt": "You are a fast worker. The lead hands you a self-contained subtask. Do EXACTLY what you are given - concisely, correctly, completely. You only have what is in the task; rely on it. Return just the result, no preamble."
    }
  }
}
