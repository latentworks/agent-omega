# Agent Omega .gitignore
# Covers the Node.js sidecar, the .NET (C#/WinForms/WebView2) app, and the
# Python web bridge. The engine binary is NOT tracked here -- it ships as a
# GitHub Release download and is fetched at install time.

# --- Node.js ---
node_modules/

# --- .NET build output ---
bin/
obj/
*.user

# --- Python ---
__pycache__/

# --- Databases / persisted state ---
*.db
*.db-wal
*.db-shm
*.sqlite*

# --- Logs & structured logs ---
*.log
*.jsonl

# --- Runtime / working data ---
workspace/
.omega-staging-backup/

# --- Secrets & local env ---
.env

# --- Engine binary (shipped via GitHub Release, never committed) ---
*.exe
engine/

# --- macOS shell build artifacts (source in mac/ is tracked; binaries/tests aren't) ---
mac/AgentOmega
mac/sidecar-bin
mac/build/
_smoke/

# Note: config-template/ is shipped source and is intentionally tracked.

# internal roadmap/testing docs — never publish
HARNESS_PROPOSALS.md
HARNESS_RUBRIC.md
_bench*/
UI_BACKLOG.md
